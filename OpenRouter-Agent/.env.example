# Copy to `.env` (gitignored). Never commit real keys.

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Model override (optional). Defaults to ~anthropic/claude-sonnet-latest.
# Repo alternatives: nvidia/nemotron-3-ultra-550b-a55b, poolside/laguna-m.1
# OPENROUTER_MODEL=~anthropic/claude-sonnet-latest

# Financial Modeling Prep — https://financialmodelingprep.com
FMP_API_KEY=your_fmp_key_here
