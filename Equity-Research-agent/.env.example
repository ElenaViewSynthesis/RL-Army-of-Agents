# W&B API key — get yours at https://wandb.ai/authorize (used for Weave tracing)
WANDB_API_KEY=wandb_v1_...

# OpenRouter API key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Financial Modeling Prep API key — get yours at https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# Direct Anthropic API (not used — kept for reference if switching back)
# ANTHROPIC_API_KEY=sk-ant-...

# ── AWS S3 — primary storage bucket ──────────────────────────────────────────
# Create an IAM user with s3:PutObject on the bucket and paste credentials here.
# Bucket must exist in AWS console before the server starts.
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_S3_REGION=eu-west-1
AWS_S3_BUCKET=your-bucket-name-here

# AWS Bedrock (not used — kept for reference if switching back)
# AWS_REGION=us-east-1
