# Copy to `.env` inside finance_coordinator/ (ADK loads the .env next to the
# agent package) OR export these in your shell before running `adk`.

# --- Gemini via Google AI Studio (simplest) ---
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your_google_ai_studio_key_here

# --- OR Gemini via Vertex AI (enterprise) ---
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Model override (optional) ---
# ADK_MODEL=gemini-2.5-pro
