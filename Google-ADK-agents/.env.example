# Copy to `.env` inside finance_coordinator/ (ADK loads the .env next to the
# agent package) OR export these in your shell before running `adk`.

# --- Gemini via Google AI Studio (simplest) ---
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GEMINI_API_KEY=your_google_ai_studio_key_here

# --- OR Gemini via Vertex AI (enterprise) ---
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Gemini model override (optional) ---
# ADK_MODEL=gemini-2.5-pro

# --- OpenRouter (open reasoning model via LiteLLM, for the valuation agent) ---
OPENROUTER_API_KEY=your_openrouter_key_here
# OPENROUTER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
# OPENROUTER_REASONING=1   # set to 0/false to disable reasoning (non-reasoning models)

# --- Financial Modeling Prep (market-data tools) ---
# Free tier from financialmodelingprep.com covers the core endpoints.
FMP_API_KEY=your_fmp_key_here

# --- Supabase (optional A2A persistence) ---
# a2a_finance/storage.py writes runs / prices / responses via the Supabase REST
# API. Leave these unset to run with persistence disabled (everything no-ops).
# Use the SERVICE-ROLE secret key (sb_secret_...): RLS is enabled with no
# policies, so the publishable/anon key is blocked by design. Keep it secret.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SECRET_KEY=sb_secret_your_service_role_key_here

# --- Langfuse tracing (optional observability) ---
# Install the extra: `uv sync --extra observability`. Leave unset to run untraced
# (a2a_finance/observability.init_tracing() no-ops). Keys: Langfuse UI → Settings
# → API Keys. LANGFUSE_BASE_URL = https://cloud.langfuse.com (EU),
# https://us.cloud.langfuse.com (US), or your self-hosted URL.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
